# =====================================================================
# Topper Mantra Backend Configuration
# =====================================================================

# ---------------------------------------------------------------------
# SUPABASE
# ---------------------------------------------------------------------
# Find these in your Supabase Project Settings -> API
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# DO NOT EXPOSE THIS IN THE FRONTEND (.env.local only for backend scripts)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---------------------------------------------------------------------
# APP CONFIG
# ---------------------------------------------------------------------
VITE_APP_ENV="development" # development | staging | production
VITE_API_URL="http://localhost:3000"

# ---------------------------------------------------------------------
# REDIS (Prepared for future caching layer)
# ---------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ---------------------------------------------------------------------
# MEILISEARCH (Prepared for future full text search)
# ---------------------------------------------------------------------
# VITE_MEILISEARCH_URL=""
# VITE_MEILISEARCH_SEARCH_KEY=""
