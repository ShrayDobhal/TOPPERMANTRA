generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                 String              @id @default(uuid())
  clerkId            String              @unique
  email              String              @unique
  fullName           String
  profileImage       String?
  bio                String?
  college            String?
  university         String?
  branch             String?
  year               String?
  city               String?
  state              String?
  country            String?
  careerGoal         String?
  experienceLevel    String?
  linkedin           String?
  github             String?
  portfolio          String?
  resume             String?
  xp                 Int                 @default(0)
  level              Int                 @default(1)
  streak             Int                 @default(0)
  longestStreak      Int                 @default(0)
  communityScore     Int                 @default(0)
  contributionScore  Int                 @default(0)
  lastActiveAt       DateTime            @default(now())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  interests          UserInterest[]
  skills             UserSkill[]
  notifications      Notification[]
  cohortMemberships  CohortMember[]
  claimedSubparts    ProjectSubpart[]    @relation("ClaimedBy")
  submissions        Submission[]
  aidRequests        AidRequest[]
  hubPosts           HubPost[]
  hubComments        HubComment[]
  badges             UserBadge[]
  freezes            Freeze[]
  waitlistEntries    Waitlist[]
  challengeResponses ChallengeResponse[]
}

model UserInterest {
  id       String @id @default(uuid())
  userId   String
  interest String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSkill {
  id          String  @id @default(uuid())
  userId      String
  skill       String
  proficiency String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  type        String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// PILLAR 1: COHORT (Group Mentorship)
// ============================================================

model Cohort {
  id                String            @id @default(uuid())
  name              String
  branch            String
  mentorId          String
  mentorName        String
  mentorInstitution String?
  maxSize           Int               @default(50)
  currentWeek       Int               @default(1)
  status            String            @default("active") // active | archived
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  members           CohortMember[]
  challenges        CohortChallenge[]
}

model CohortMember {
  id             String    @id @default(uuid())
  userId         String
  cohortId       String
  status         String    @default("active") // active | yellow | red | removed
  joinedAt       DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  yellowFlagDate DateTime?
  removedAt      DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cohort         Cohort    @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  @@unique([userId, cohortId])
}

model CohortChallenge {
  id          String              @id @default(uuid())
  cohortId    String
  week        Int
  title       String
  description String              
  postedBy    String
  status      String              @default("active") // active | closed
  createdAt   DateTime            @default(now())
  deadline    DateTime
  cohort      Cohort              @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  responses   ChallengeResponse[]
}

model ChallengeResponse {
  id          String          @id @default(uuid())
  challengeId String
  userId      String
  content     String          
  upvotes     Int             @default(0)
  createdAt   DateTime        @default(now())
  challenge   CohortChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// PILLAR 2: PROJECT FORGE
// ============================================================

model Project {
  id                String           @id @default(uuid())
  title             String
  description       String           
  mentorId          String
  mentorName        String
  mentorInstitution String?
  branch            String
  techStack         String           @default("[]")
  difficulty        String           @default("Intermediate")
  status            String           @default("active") // active | archived
  lastSubmissionAt  DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  subparts          ProjectSubpart[]
}

model ProjectSubpart {
  id             String       @id @default(uuid())
  projectId      String
  title          String
  description    String       
  status         String       @default("available") // available | claimed | completed
  difficulty     String       @default("Intermediate")
  estimatedHours Int          @default(10)
  xpReward       Int          @default(100)
  claimedById    String?
  claimedAt      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  mergedBy       String?
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  claimedBy      User?        @relation("ClaimedBy", fields: [claimedById], references: [id])
  aidRequests    AidRequest[]
  submissions    Submission[]
  waitlist       Waitlist[]
}

model AidRequest {
  id          String         @id @default(uuid())
  subpartId   String
  userId      String
  type        String // video | code
  description String         
  videoUrl    String?
  codeContent String?        
  status      String         @default("open") // open | resolved
  createdAt   DateTime       @default(now())
  subpart     ProjectSubpart @relation(fields: [subpartId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Submission {
  id          String         @id @default(uuid())
  subpartId   String
  userId      String
  codeUrl     String?
  demoUrl     String?
  notes       String?        
  status      String         @default("pending") // pending | approved | rejected
  reviewedBy  String?
  reviewNote  String?        
  submittedAt DateTime       @default(now())
  reviewedAt  DateTime?
  subpart     ProjectSubpart @relation(fields: [subpartId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Waitlist {
  id        String         @id @default(uuid())
  subpartId String
  userId    String
  position  Int
  createdAt DateTime       @default(now())
  subpart   ProjectSubpart @relation(fields: [subpartId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([subpartId, userId])
}

// ============================================================
// PILLAR 3: COMMUNITY HUB
// ============================================================

model Channel {
  id        String    @id @default(uuid())
  name      String
  branch    String?
  type      String    @default("branch") // branch | global
  createdAt DateTime  @default(now())
  posts     HubPost[]
}

model HubPost {
  id        String       @id @default(uuid())
  channelId String
  userId    String
  tag       String // doubt | resource | showcase | discussion
  title     String
  content   String       
  upvotes   Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  channel   Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  HubComment[]
}

model HubComment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String   
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  post      HubPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// GAMIFICATION ENGINE
// ============================================================

model Badge {
  id           String      @id @default(uuid())
  name         String      @unique
  description  String
  icon         String
  criteriaType String // mergedSubparts | upvotesGiven | streak | etc
  threshold    Int
  createdAt    DateTime    @default(now())
  userBadges   UserBadge[]
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// ============================================================
// FREEZE & GOVERNANCE
// ============================================================

model Freeze {
  id         String   @id @default(uuid())
  userId     String
  reason     String
  approvedBy String?
  status     String   @default("pending") // pending | approved | rejected
  startDate  DateTime
  endDate    DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
